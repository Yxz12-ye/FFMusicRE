export global MusicPalette {
    out property <brush> app-background-start: #0A0E14;
    out property <brush> app-background-end: #101722;
    out property <brush> shell: #0E1520CC;
    out property <brush> surface-0: #141D2ACC;
    out property <brush> surface-1: #192434B8;
    out property <brush> surface-2: #223046C8;
    out property <brush> surface-selected: #24394FD6;
    out property <brush> accent: #79C0FF;
    out property <brush> accent-soft: #67A6FF;
    out property <brush> success: #8CD7B0;
    out property <brush> text-primary: #F3F6FB;
    out property <brush> text-secondary: #A6B3C5;
    out property <brush> text-muted: #70829A;
    out property <brush> divider: #2B3A52CC;
    out property <brush> shadow: #00000066;
}

export global MusicTypography {
    out property <string> heading-family: "Microsoft YaHei UI";
    out property <string> body-family: "Microsoft YaHei UI";
    out property <string> mono-family: "Consolas";
    out property <length> title-size: 40px;
