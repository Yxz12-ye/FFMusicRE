import { FocusTouchArea } from "focus-touch-area.slint";
import { MusicPalette, MusicTypography } from "theme.slint";

export component ActionCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    callback clicked;
    callback secondary-clicked;

    min-height: 82px;
    min-width: 150px;
    border-radius: 18px;
    background: touch.pressed ? MusicPalette.surface-1.darker(10%) : MusicPalette.surface-1;
    clip: true;
    accessible-role: button;
    accessible-action-default => { touch.clicked(); }

    touch := FocusTouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
        secondary-clicked => { root.secondary-clicked(); }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 6px;

        Text {
            text: root.title;
            color: MusicPalette.text-primary;
            font-family: MusicTypography.heading-family;
            font-size: 17px;
            font-weight: FontWeight.bold;
            horizontal-alignment: left;
        }

        Text {
            text: root.subtitle;
            color: MusicPalette.text-secondary;
            font-family: MusicTypography.body-family;
            font-size: MusicTypography.meta-size;
            wrap: word-wrap;
            horizontal-alignment: left;
        }
    }
}
